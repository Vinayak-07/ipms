rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isDeviceMember(deviceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.deviceId == deviceId;
    }

    function hasValidSensorTypes() {
      return (!('temperature' in request.resource.data) || request.resource.data.temperature is number)
        && (!('ppm' in request.resource.data) || request.resource.data.ppm is number)
        && (!('humidity' in request.resource.data) || request.resource.data.humidity is number);
    }

    function hasAnySensorValue() {
      return ('temperature' in request.resource.data)
        || ('ppm' in request.resource.data)
        || ('humidity' in request.resource.data);
    }

    function isValidDeviceRootWrite(deviceId) {
      return request.resource.data.keys().hasOnly([
          'deviceId',
          'temperature',
          'ppm',
          'humidity',
          'timestamp',
          'recordedAt',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.deviceId == deviceId
        && hasAnySensorValue()
        && hasValidSensorTypes();
    }

    function isValidDeviceHistoryWrite(deviceId) {
      return request.resource.data.keys().hasOnly([
          'deviceId',
          'temperature',
          'ppm',
          'humidity',
          'timestamp',
          'recordedAt',
          'createdAt',
          'updatedAt'
        ])
        && (!('deviceId' in request.resource.data) || request.resource.data.deviceId == deviceId)
        && hasAnySensorValue()
        && hasValidSensorTypes();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /devices/{deviceId} {
      allow read: if isDeviceMember(deviceId);
      allow create, update: if isValidDeviceRootWrite(deviceId);
      allow delete: if false;

      match /data/{docId} {
        allow read: if isDeviceMember(deviceId);
        allow create, update: if isValidDeviceHistoryWrite(deviceId);
        allow delete: if false;
      }
    }
  }
}
